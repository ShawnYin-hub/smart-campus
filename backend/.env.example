# ============================================================
# 数据库配置
# ============================================================
# 格式：postgresql+asyncpg://用户名:密码@主机:端口/数据库名
DATABASE_URL=sqlite:///./smart_campus.db

# ============================================================
# JWT 安全配置
# ============================================================
# 生产环境：请使用以下命令生成一个随机的 64 位密钥
# python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=changeme-replace-with-secure-random-key-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ============================================================
# DeepSeek AI 配置
# ============================================================
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ============================================================
# CORS 配置
# ============================================================
# 逗号分隔的前端地址列表（不要带尾部斜杠）
# 开发环境：
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
# 生产环境示例：
# BACKEND_CORS_ORIGINS=["https://campus.your-school.edu.cn"]

# ============================================================
# 服务器配置
# ============================================================
DEBUG=false
APP_NAME=BHSFIC Smart Campus
APP_VERSION=1.0.0
