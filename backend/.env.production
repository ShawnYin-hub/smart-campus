# ============================================================
# 生产环境配置文件
# 复制此文件为 backend/.env 并填写真实值
# ============================================================

# ---------- 数据库 ----------
# SQLite 仅供本地开发，生产环境使用 PostgreSQL
# 此配置由 docker-compose.yml 中的环境变量覆盖，无需修改
# DATABASE_URL=postgresql://postgres:postgres@db:5432/smart_campus

# ---------- JWT 安全 ----------
# 【重要】生产环境必须更换为随机密钥
# 生成方法（本地执行）:
#   Linux/Mac:  openssl rand -hex 64
#   Windows:    python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=changeme-replace-with-secure-random-key

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ---------- DeepSeek AI ----------
# 从 https://platform.deepseek.com 获取 API Key
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ---------- CORS ----------
# Nginx 反向代理后同源，设为通配符即可
# 若前后端分离部署（不同域名），改为前端实际域名
BACKEND_CORS_ORIGINS=["*"]

# ---------- 服务模式 ----------
DEBUG=false
